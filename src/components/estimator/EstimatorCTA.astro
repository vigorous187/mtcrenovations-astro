---
interface Props {
  serviceSlug: string;
  serviceName: string;
}

const { serviceSlug, serviceName } = Astro.props;
---

<section class="py-5 bg-dark text-white">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-5">
        <span class="badge bg-danger mb-3">Free Price Guide</span>
        <h2 class="fw-bold mb-3">How much does a {serviceName.toLowerCase()} renovation cost?</h2>
        <p class="text-white-50 mb-4">
          80% of homeowners want a rough price before they call. Use our online estimator to get a safe range in under a minute — no sign-up required.
        </p>
        <ul class="list-unstyled text-white-50 small mb-0">
          <li class="mb-2"><i class="fas fa-check text-danger me-2"></i>Ballpark range, not a locked quote</li>
          <li class="mb-2"><i class="fas fa-check text-danger me-2"></i>Customize with optional add-ons</li>
          <li><i class="fas fa-check text-danger me-2"></i>Share results when you request a quote</li>
        </ul>
      </div>
      <div class="col-lg-7">
        <div class="card border-0 shadow-lg p-4 p-md-5 text-center">
          <i class="fas fa-calculator text-danger mb-3" style="font-size: 2.5rem;"></i>
          <h3 class="h5 fw-bold text-dark mb-2">{serviceName} Cost Estimator</h3>
          <p class="text-secondary small mb-4">Pre-selected for {serviceName.toLowerCase()} projects in Burlington &amp; Hamilton.</p>
          <a href={`/estimate/?type=${serviceSlug}`} class="btn btn-danger btn-lg px-5">
            Get Your Price Range
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
