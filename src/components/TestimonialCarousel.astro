---
import reviews from '../data/reviews.json';
import site from '../data/site.json';
---

<section class="py-5 bg-light">
  <div class="container">
    <!-- Google Reviews Header -->
    <div class="text-center mb-4">
      <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
        <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span class="fw-bold fs-5">Google Reviews</span>
      </div>
      <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
        <span class="fw-bold fs-4">{site.googleReviews.rating}</span>
        <div class="google-stars">
          {[...Array(5)].map((_, i) => (
            <svg width="20" height="20" viewBox="0 0 24 24" fill={i < Math.floor(site.googleReviews.rating) ? '#FBBC05' : '#E0E0E0'}>
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <span class="text-secondary">({site.googleReviews.count}+ reviews)</span>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="row g-4">
      {reviews.map((review) => (
        <div class="col-12 col-md-6 col-lg-4">
          <div class="review-card h-100 bg-white rounded shadow-sm p-4" style="border-left: 4px solid #4285F4;">
            <!-- Stars -->
            <div class="mb-3">
              {[...Array(5)].map((_, si) => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill={si < review.rating ? '#FBBC05' : '#E0E0E0'} style="margin: 0 1px;">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <!-- Quote -->
            <p class="fst-italic text-secondary mb-3">"{review.text}"</p>
            <!-- Reviewer -->
            <p class="fw-bold mb-0">{review.name}</p>
            <p class="text-secondary small mb-0">{review.city}, Ontario</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Link to Google Reviews -->
    {site.googleReviews.url && (
      <div class="text-center mt-4">
        <a href={site.googleReviews.url} target="_blank" rel="noopener" class="text-decoration-none text-secondary small">
          <svg width="16" height="16" viewBox="0 0 24 24" class="me-1" style="vertical-align: -2px;">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          See all reviews on Google
        </a>
      </div>
    )}
  </div>
</section>
