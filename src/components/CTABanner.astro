---
import site from '../data/site.json';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = 'Ready to Start Your Renovation?',
  subtitle = `Join ${site.googleReviews.count}+ satisfied homeowners across Hamilton and the GTA.`,
  ctaText = 'Get Free Estimate',
  ctaLink = '/estimate/',
} = Astro.props;
---

<section class="py-5 text-center gradient-mesh">
  <div class="container reveal">
    <h2 class="font-display fw-bold mb-3" style="font-size: clamp(1.75rem, 3vw, 3rem); color: var(--text-primary);">{title}</h2>
    <p class="mb-4 mx-auto" style="max-width: 600px; color: var(--text-secondary);">{subtitle}</p>
    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
      <a href={ctaLink} class="btn btn-danger btn-lg px-5 py-3">
        {ctaText}
      </a>
      <a href={`tel:${site.phone.replace(/[^+\d]/g, '')}`} class="btn-ghost rounded-pill d-inline-flex align-items-center justify-content-center">
        <i class="fas fa-phone me-2"></i>{site.phone}
      </a>
    </div>
  </div>
</section>
