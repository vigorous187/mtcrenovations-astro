---
interface Props {
  service: string;
  serviceName: string;
}

const { service, serviceName } = Astro.props;

// Use Astro glob to find our-work images at build time
const allImages = import.meta.glob('/public/assets/img/*/our-work/*.{jpg,jpeg,png,webp}');
const serviceImages = Object.keys(allImages)
  .filter(path => path.includes(`/${service}/our-work/`))
  .map(path => path.replace('/public', ''))
  .sort()
  .slice(0, 12);
---

<section class="py-5">
  <div class="container">
    <h2 class="text-center fw-bold mb-2">Our {serviceName} Renovation Work</h2>
    <p class="text-center text-secondary mb-4">Browse completed projects from Hamilton and the GTA</p>

    {serviceImages.length > 0 ? (
      <div class="row g-3">
        {serviceImages.map((img, i) => (
          <div class="col-6 col-md-4 col-lg-3">
            <div class="portfolio-item overflow-hidden rounded shadow-sm">
              <img
                src={img}
                alt={`${serviceName} renovation project in Hamilton - ${i + 1}`}
                class="w-100"
                style="height: 220px; object-fit: cover; transition: transform 0.3s ease;"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-center text-secondary">Portfolio photos coming soon.</p>
    )}
  </div>
</section>

<style>
  .portfolio-item:hover img {
    transform: scale(1.05);
  }
</style>
