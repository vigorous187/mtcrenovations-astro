---
import site from '../data/site.json';
import services from '../data/services.json';

const currentPath = Astro.url.pathname;
---

<header>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
    <div class="container">
      <!-- Logo -->
      <a class="navbar-brand" href="/">
        <img src="/assets/img/logo/logo.png" alt={site.name} style="height: 50px; width: auto; max-height: 50px;" />
      </a>

      <!-- Mobile Toggle -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNav"
        aria-controls="mainNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Nav Links -->
      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item">
            <a class:list={['nav-link', { active: currentPath === '/' }]} href="/">Home</a>
          </li>

          <!-- Services Dropdown -->
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              Services
            </a>
            <ul class="dropdown-menu">
              {services.map(s => (
                <li>
                  <a class="dropdown-item" href={`/${s.slug}/`}>{s.name} Renovation</a>
                </li>
              ))}
            </ul>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/locations/">Locations</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/blog/">Blog</a>
          </li>
          <li class="nav-item">
            <a class:list={['nav-link', { active: currentPath === '/faq/' }]} href="/faq/">FAQ</a>
          </li>

          <!-- Login -->
          <li class="nav-item">
            <a class="nav-link" href={site.jobtreadLogin} target="_blank" rel="noopener">
              <i class="fas fa-sign-in-alt me-1"></i>Login
            </a>
          </li>

          <!-- Phone -->
          <li class="nav-item d-none d-lg-block">
            <a class="nav-link" href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}>
              <i class="fas fa-phone me-1"></i>{site.phone}
            </a>
          </li>

          <!-- CTA -->
          <li class="nav-item ms-lg-2">
            <a class="btn btn-danger btn-sm px-3" href="/basement/get-free-quote/">
              Get Free Estimate
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
  <!-- Spacer for fixed navbar -->
  <div style="height: 70px;"></div>
</header>
