---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  schema?: object | object[];
  noindex?: boolean;
}

import site from '../data/site.json';

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, `https://${site.domain}`).href,
  ogImage = `https://${site.domain}/assets/img/og-default.png`,
  ogType = 'website',
  schema,
  noindex = false,
} = Astro.props;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- Canonical -->
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="en-CA" href={canonical} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={site.name} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD Schemas -->
{schemas.map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
