---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title,
  subtitle,
  backgroundImage = '/assets/img/home/hero.jpg',
  ctaText = 'Get Free Estimate',
  ctaLink = '/estimate/',
} = Astro.props;
---

<section
  class="position-relative d-flex align-items-center"
  style="min-height: 60vh;"
>
  <div
    class="position-absolute w-100 h-100"
    style={`background: url('${backgroundImage}') center/cover no-repeat; top: 0; left: 0;`}
  ></div>
  <div class="hero-overlay"></div>
  <div class="container position-relative text-center py-5" style="z-index: 2;">
    <h1 class="font-display fw-bold mb-3" style="font-size: clamp(2.5rem, 5vw, 4.5rem); color: var(--text-primary);">{title}</h1>
    {subtitle && <p class="h5 fw-normal mb-4" style="color: var(--text-secondary);">{subtitle}</p>}
    <a href={ctaLink} class="btn btn-danger btn-lg px-5 py-3">
      {ctaText}
    </a>
  </div>
</section>
