---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbList } from '../components/seo/schemas';

const title = 'Privacy Policy | MTC Renovations';
const description = 'MTC Renovations privacy policy. Learn how we collect, use, and protect your personal information in compliance with Ontario PIPEDA requirements.';
const canonical = 'https://www.mtcrenovations.ca/privacy-policy/';

const breadcrumb = breadcrumbList([
  { name: 'Home', url: 'https://www.mtcrenovations.ca/' },
  { name: 'Privacy Policy', url: canonical },
]);
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schema={breadcrumb}
  noindex={false}
>
  <section class="py-5">
    <div class="container" style="max-width: 800px;">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item active" aria-current="page">Privacy Policy</li>
        </ol>
      </nav>

      <h1 class="mb-2">Privacy Policy</h1>
      <p class="text-muted small mb-5">Last updated: March 2025</p>

      <p>MTC Renovations ("we," "us," or "our") is committed to protecting your personal information. This Privacy Policy explains how we collect, use, disclose, and safeguard information you provide when you visit our website or request our services. We operate in compliance with Canada's <em>Personal Information Protection and Electronic Documents Act</em> (PIPEDA) and applicable Ontario privacy law.</p>

      <h2 class="h4 mt-5 mb-3">1. Information We Collect</h2>
      <p>We collect personal information only when you voluntarily provide it to us. This includes:</p>
      <ul>
        <li><strong>Name</strong> — to address you properly in correspondence.</li>
        <li><strong>Email address</strong> — to send quote follow-ups, project updates, and replies to your inquiries.</li>
        <li><strong>Phone number</strong> — to schedule consultations and discuss your project.</li>
        <li><strong>Project details and address</strong> — to assess scope and provide an accurate estimate.</li>
      </ul>
      <p>We do not collect payment card information through this website. Payments are handled through secure third-party processors.</p>

      <h2 class="h4 mt-5 mb-3">2. How We Use Your Information</h2>
      <p>We use the information you provide solely to:</p>
      <ul>
        <li>Respond to your inquiry or quote request in a timely manner.</li>
        <li>Schedule an in-home consultation or site visit.</li>
        <li>Prepare and deliver renovation estimates.</li>
        <li>Communicate project timelines, updates, and follow-ups.</li>
        <li>Improve our website and service offerings.</li>
      </ul>
      <p>We will not use your information for unsolicited marketing without your explicit consent.</p>

      <h2 class="h4 mt-5 mb-3">3. We Do Not Sell Your Data</h2>
      <p>We do not sell, rent, trade, or otherwise transfer your personal information to third parties for their own marketing purposes. Period.</p>

      <h2 class="h4 mt-5 mb-3">4. Information Sharing</h2>
      <p>We may share your information only in the following limited circumstances:</p>
      <ul>
        <li><strong>Service providers</strong> — trusted third parties who assist us in operating our business (e.g., project management software, scheduling tools), subject to confidentiality agreements.</li>
        <li><strong>Legal requirements</strong> — if required by law, court order, or governmental authority.</li>
        <li><strong>Business transfers</strong> — in the event of a merger or acquisition, subject to equivalent privacy protections.</li>
      </ul>

      <h2 class="h4 mt-5 mb-3">5. Cookies and Analytics</h2>
      <p>Our website uses the following cookies and tracking technologies:</p>
      <ul>
        <li><strong>Google Analytics</strong> — we use Google Analytics to understand how visitors interact with our site (pages visited, time on site, traffic sources). This data is aggregated and anonymous. You can opt out via <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google's opt-out browser add-on</a>.</li>
        <li><strong>Cloudflare</strong> — our site is served through Cloudflare, which may set cookies for security and performance purposes. See <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener">Cloudflare's Privacy Policy</a>.</li>
      </ul>
      <p>You can control cookies through your browser settings. Disabling cookies may affect certain website functionality.</p>

      <h2 class="h4 mt-5 mb-3">6. Data Retention</h2>
      <p>We retain your personal information only as long as necessary to fulfill the purpose it was collected for, or as required by law. Project records are typically retained for seven years in accordance with Ontario business record-keeping requirements.</p>

      <h2 class="h4 mt-5 mb-3">7. Security</h2>
      <p>We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, disclosure, alteration, or destruction. However, no internet transmission is 100% secure, and we cannot guarantee absolute security.</p>

      <h2 class="h4 mt-5 mb-3">8. Your Rights Under PIPEDA</h2>
      <p>Under PIPEDA, you have the right to:</p>
      <ul>
        <li>Know what personal information we hold about you.</li>
        <li>Request access to your personal information.</li>
        <li>Request correction of inaccurate information.</li>
        <li>Withdraw consent to our use of your information (subject to legal or contractual restrictions).</li>
        <li>Lodge a complaint with the Office of the Privacy Commissioner of Canada.</li>
      </ul>

      <h2 class="h4 mt-5 mb-3">9. Contact Us for Privacy Questions</h2>
      <p>If you have questions, concerns, or requests regarding this Privacy Policy or our data practices, please contact us:</p>
      <address class="mt-3">
        <strong>MTC Renovations</strong><br />
        Burlington &amp; Hamilton, Ontario<br />
        Email: <a href="mailto:info@mtcrenovations.ca">info@mtcrenovations.ca</a><br />
        Phone: <a href="tel:+16475601095">(647) 560-1095</a>
      </address>
      <p class="mt-3">We will respond to privacy requests within 30 days.</p>

      <h2 class="h4 mt-5 mb-3">10. Updates to This Policy</h2>
      <p>We may update this Privacy Policy from time to time. The "Last updated" date at the top of this page will reflect any changes. Continued use of our website after changes constitutes acceptance of the updated policy.</p>
    </div>
  </section>
</BaseLayout>
