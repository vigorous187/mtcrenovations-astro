---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vendor Application | MTC Renovations"
  description="Apply to become a vendor or subcontractor with MTC Renovations in Hamilton and the GTA."
  noindex={true}
>
  <section class="py-5 bg-dark text-white text-center">
    <div class="container">
      <h1 class="fw-bold">Vendor / Subcontractor Application</h1>
      <p class="text-white-50">Partner with MTC Renovations</p>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
          <div data-jobtread-vendor-form></div>
        </div>
      </div>
    </div>
  </section>

  <Fragment set:html={`
    <style>.jtwf{font-family:inherit}.jtwf .max-w-sm{max-width:100%!important}</style>
    <script>
      document.addEventListener('DOMContentLoaded',function(){
        var c=document.querySelector('[data-jobtread-vendor-form]');
        if(c){
          c.innerHTML='<form class="jtwf" data-jobtread-web-form="true" data-key="22SRGd5DNgcfkDs9SPWqy7kuPFa4fGFpCE" data-success-message="Thank you for reaching out! We will respond shortly!" data-success-url="https://mtcrenovations.ca"><div class="mx-auto min-w-0 rounded-sm shadow-sm bg-white"><div class="p-4 space-y-2"><label class="cursor-pointer block"><div class="font-bold">Company Name <span class="font-normal text-red-500">*</span></div><input class="rounded-sm ring ring-gray-200 p-2 w-full bg-white appearance-none transition focus-within:ring-3 focus-within:ring-blue-500" type="text" required name="contact.name"/></label><label class="cursor-pointer block"><div class="font-bold">Phone <span class="font-normal text-red-500">*</span></div><input class="rounded-sm ring ring-gray-200 p-2 w-full bg-white appearance-none transition focus-within:ring-3 focus-within:ring-blue-500" type="tel" required name="account.custom.22NgpjG45eL4"/></label><label class="cursor-pointer block"><div class="font-bold">Email <span class="font-normal text-red-500">*</span></div><input class="rounded-sm ring ring-gray-200 p-2 w-full bg-white appearance-none transition focus-within:ring-3 focus-within:ring-blue-500" type="email" required name="account.custom.22NgpjFtDL3v"/></label><label class="cursor-pointer block"><div class="font-bold">Address <span class="font-normal text-red-500">*</span></div><textarea class="rounded-sm ring ring-gray-200 p-2 w-full bg-white appearance-none transition focus-within:ring-3 focus-within:ring-blue-500" name="location.address" required></textarea></label><label class="cursor-pointer block"><div class="font-bold">Website</div><input class="rounded-sm ring ring-gray-200 p-2 w-full bg-white appearance-none transition focus-within:ring-3 focus-within:ring-blue-500" name="account.custom.22Nh8UaiNz4j"/></label><div class="block"><div class="font-bold">Trade(s)</div><div class="text-gray-500">What trades do you do?</div><div class="rounded-sm border divide-y overflow-hidden"><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Basements"/><div class="grow min-w-0">Basements</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Carpentry"/><div class="grow min-w-0">Carpentry</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Demolition"/><div class="grow min-w-0">Demolition</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Drywall/Boarder"/><div class="grow min-w-0">Drywall/Boarder</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Electrical"/><div class="grow min-w-0">Electrical</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Flooring"/><div class="grow min-w-0">Flooring</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Framing"/><div class="grow min-w-0">Framing</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="HVAC"/><div class="grow min-w-0">HVAC</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Insulation"/><div class="grow min-w-0">Insulation</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Painting"/><div class="grow min-w-0">Painting</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Plumbing"/><div class="grow min-w-0">Plumbing</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Tile Setter"/><div class="grow min-w-0">Tile Setter</div></label><label class="flex gap-2 items-center p-2 cursor-pointer block"><input class="shrink-0" type="checkbox" name="account.custom.22Nh8TYnQPBt" value="Other"/><div class="grow min-w-0">Other</div></label></div></div><div class="text-right"><button class="text-right px-4 py-2 rounded-sm shadow-xs cursor-pointer" data-submit-button="true" style="background-color:#a31314;color:#f6e7e8">Submit</button></div></div></div></form>';
          var s=document.createElement('script');
          s.src='https://app.jobtread.com/web-form.js';
          s.async=true;
          document.body.appendChild(s);
        }
      });
    </script>
  `} />
</BaseLayout>
