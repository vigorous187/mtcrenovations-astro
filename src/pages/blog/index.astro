---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { breadcrumbList } from '../../components/seo/schemas';
import site from '../../data/site.json';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const schemas = [
  breadcrumbList([
    { name: 'Home', url: site.url },
    { name: 'Blog', url: `${site.url}/blog` },
  ]),
];
---

<BaseLayout
  title="Renovation Blog | Tips & Guides | MTC Renovations"
  description="Renovation tips, guides, and project insights from MTC Renovations in Hamilton. Learn about basement finishing, kitchen remodels, and more."
  schema={schemas}
>
  <section class="bg-dark text-white py-5 text-center">
    <div class="container py-4">
      <h1 class="display-5 fw-bold mb-3">Renovation Blog</h1>
      <p class="lead text-white-50">Tips, guides, and project insights from Hamilton's trusted contractor</p>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      {posts.length > 0 ? (
        <div class="row g-4">
          {posts.map(post => (
            <div class="col-md-6 col-lg-4">
              <a href={`/blog/${post.slug}/`} class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                  {post.data.coverImage && (
                    <img src={post.data.coverImage} alt={post.data.title} class="card-img-top" loading="lazy" />
                  )}
                  <div class="card-body">
                    <p class="text-secondary small mb-2">{post.data.datePublished}</p>
                    <h3 class="h5 fw-bold text-dark">{post.data.title}</h3>
                    <p class="text-secondary small">{post.data.metaDescription}</p>
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-5">
          <p class="text-secondary">Blog posts coming soon. Check back for renovation tips and project insights.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
