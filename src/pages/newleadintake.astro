---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { localBusiness } from '../components/seo/schemas';

const schemas = [localBusiness()];
---

<BaseLayout
  title="Get a Free Quote | MTC Renovations"
  description="Request a free renovation quote from MTC Renovations. Serving Burlington, Hamilton & the GTA."
  noindex={true}
  schema={schemas}
>
  <section class="py-5 bg-dark text-white text-center">
    <div class="container">
      <h1 class="fw-bold">Get a Free Quote</h1>
      <p class="text-white-50">Fill out the form below and we'll get back to you within 24 hours</p>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <form id="leadForm" novalidate>
                <div class="mb-3">
                  <label for="name" class="form-label">Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="name" name="name" required />
                  <div class="invalid-feedback">Please enter your name.</div>
                </div>

                <div class="mb-3">
                  <label for="phone" class="form-label">Phone <span class="text-danger">*</span></label>
                  <input type="tel" class="form-control" id="phone" name="phone" required />
                  <div class="invalid-feedback">Please enter your phone number.</div>
                </div>

                <div class="mb-3">
                  <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                  <input type="email" class="form-control" id="email" name="email" required />
                  <div class="invalid-feedback">Please enter a valid email.</div>
                </div>

                <div class="mb-3">
                  <label for="hearAbout" class="form-label">How did you hear about us? <span class="text-danger">*</span></label>
                  <select class="form-select" id="hearAbout" name="hearAbout" required>
                    <option value="">Choose one...</option>
                    <option value="Price Guide">Price Guide</option>
                    <option value="Referral">Referral</option>
                    <option value="Google">Google</option>
                    <option value="Facebook">Facebook</option>
                    <option value="Instagram">Instagram</option>
                    <option value="Internet Search">Internet Search</option>
                    <option value="Home Advisor">Home Advisor</option>
                    <option value="Other">Other</option>
                  </select>
                  <div class="invalid-feedback">Please select an option.</div>
                </div>

                <div class="mb-3">
                  <label for="remodelType" class="form-label">Remodel Type <span class="text-danger">*</span></label>
                  <select class="form-select" id="remodelType" name="remodelType" required>
                    <option value="">Choose one...</option>
                    <option value='Remodel (includes "Full Remodel," "Kitchen Remodel," "Bathroom Remodel," "Basement Remodel," etc.)'>Remodel (basement, kitchen, bathroom, etc.)</option>
                    <option value='New Construction (includes "New Build," "Multi-unit Build," "Garage," etc'>New Construction / ADU</option>
                    <option value="Addition">Addition</option>
                    <option value="Exterior (includes &quot;Deck,&quot; &quot;Patio,&quot; &quot;Roofing,&quot; &quot;Hardscape,&quot; etc.)">Exterior</option>
                    <option value="General Contracting">General Contracting</option>
                    <option value="Other">Other</option>
                  </select>
                  <div class="invalid-feedback">Please select a remodel type.</div>
                </div>

                <div class="mb-3">
                  <label for="address" class="form-label">Address <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="address" name="address" rows="2" required></textarea>
                  <div class="invalid-feedback">Please enter your address.</div>
                </div>

                <div class="mb-3">
                  <label for="projectNotes" class="form-label">Tell us about your project <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="projectNotes" name="projectNotes" rows="4" required></textarea>
                  <div class="invalid-feedback">Please tell us about your project.</div>
                </div>

                <div id="formError" class="alert alert-danger d-none" role="alert"></div>
                <div id="formSuccess" class="alert alert-success d-none" role="alert">
                  Thank you! We'll be in touch within 24 hours.
                </div>

                <button type="submit" class="btn btn-danger btn-lg w-100" id="submitBtn">
                  Submit Request
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const estimateId = params.get('estimate') || '';
  const source = params.get('source') || '';

  const form = document.getElementById('leadForm');
  const submitBtn = document.getElementById('submitBtn');
  const formError = document.getElementById('formError');
  const formSuccess = document.getElementById('formSuccess');
  const hearSelect = document.getElementById('hearAbout');
  const notesField = document.getElementById('projectNotes');
  const remodelSelect = document.getElementById('remodelType');

  async function prefillFromEstimate() {
    const id = estimateId || sessionStorage.getItem('mtc-estimate-id');

    if (hearSelect && (source === 'price-guide' || id)) {
      hearSelect.value = 'Price Guide';
    }

    if (id) {
      try {
        const res = await fetch(`/api/estimates/${id}/`);
        if (res.ok) {
          const estimate = await res.json();
          if (notesField) {
            const lines = [
              `Online price guide estimate: $${estimate.min.toLocaleString('en-CA')} – $${estimate.max.toLocaleString('en-CA')} (excl. HST)`,
              `Project: ${estimate.typeLabel}`,
              estimate.scopeLabel ? `Scope: ${estimate.scopeLabel}` : null,
              `Size: ${estimate.sizeLabel}`,
              `Finish: ${estimate.finishLabel}`,
              estimate.addonLabels?.length ? `Add-ons: ${estimate.addonLabels.join(', ')}` : null,
              `Saved estimate: ${window.location.origin}/estimate/s/${estimate.id}/`,
            ].filter(Boolean).join('\n');
            notesField.value = lines;
          }
          if (remodelSelect && estimate.scope === 'legal-suite') {
            remodelSelect.value = 'New Construction (includes "New Build," "Multi-unit Build," "Garage," etc';
          } else if (remodelSelect && !remodelSelect.value) {
            remodelSelect.value = 'Remodel (includes "Full Remodel," "Kitchen Remodel," "Bathroom Remodel," "Basement Remodel," etc.)';
          }
          return;
        }
      } catch (_) {}
    }

    const summary = sessionStorage.getItem('mtc-estimate-summary');
    if (notesField && summary && !notesField.value) {
      notesField.value = summary;
    }
  }

  prefillFromEstimate();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.classList.add('was-validated');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    formError.classList.add('d-none');
    formSuccess.classList.add('d-none');

    const id = estimateId || sessionStorage.getItem('mtc-estimate-id') || undefined;

    const payload = {
      estimateId: id,
      name: form.name.value,
      email: form.email.value,
      phone: form.phone.value,
      address: form.address.value,
      hearAbout: form.hearAbout.value,
      remodelType: form.remodelType.value,
      projectNotes: form.projectNotes.value,
    };

    try {
      const res = await fetch('/api/leads/submit/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const json = await res.json();
      if (!res.ok) throw new Error(json.error || 'Failed to submit');

      if (typeof gtag === 'function') {
        gtag('event', 'generate_lead', {
          form_name: 'price_guide_lead',
          page_path: window.location.pathname,
        });
      }

      formSuccess.classList.remove('d-none');
      form.reset();
      form.classList.remove('was-validated');
      sessionStorage.removeItem('mtc-estimate-summary');

      setTimeout(() => {
        window.location.href = id ? `/estimate/s/${id}/` : '/thank-you/';
      }, 1500);
    } catch (err) {
      formError.textContent = 'Something went wrong. Please call us at (647) 560-1095.';
      formError.classList.remove('d-none');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Request';
    }
  });
</script>
