---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import CTABanner from '../../components/CTABanner.astro';
import { localBusiness, breadcrumbList } from '../../components/seo/schemas';
import site from '../../data/site.json';
import services from '../../data/services.json';

export function getStaticPaths() {
  return services.map(s => ({
    params: { service: s.slug },
    props: { service: s },
  }));
}

const { service } = Astro.props;
const seo = service.subPages['how-it-works'];

const schemas = [
  localBusiness(),
  breadcrumbList([
    { name: 'Home', url: site.url },
    { name: `${service.name} Renovation`, url: `${site.url}/${service.slug}` },
    { name: 'How It Works', url: `${site.url}/${service.slug}/how-it-works` },
  ]),
];
---

<BaseLayout title={seo.title} description={seo.description} schema={schemas}>
  <ServiceHero
    title={`How ${service.name} Renovation Works`}
    subtitle="Our proven 5-step process from consultation to completion"
    backgroundImage={service.heroImage}
    ctaLink={`/${service.slug}/get-free-quote/`}
  />

  <ProcessSteps serviceName={service.name} />

  <section class="py-5 bg-light">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
          <h2 class="fw-bold mb-3">What to Expect</h2>
          <p class="text-secondary">
            From your first call to the final walkthrough, MTC Renovations keeps you informed every step of the way. You will receive a detailed timeline before construction starts, daily progress updates during the build, and a thorough final inspection before we consider the job complete.
          </p>
          <p class="text-secondary">
            Our team protects your home throughout the renovation. We use dust barriers, floor protection, and daily cleanup to minimize disruption to your household.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Ready to Get Started?"
    subtitle="Book your free consultation today."
    ctaLink={`/${service.slug}/get-free-quote/`}
  />
</BaseLayout>
