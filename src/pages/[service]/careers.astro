---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import CTABanner from '../../components/CTABanner.astro';
import { localBusiness, breadcrumbList } from '../../components/seo/schemas';
import site from '../../data/site.json';
import services from '../../data/services.json';

export function getStaticPaths() {
  return services.map(s => ({
    params: { service: s.slug },
    props: { service: s },
  }));
}

const { service } = Astro.props;
const seo = service.subPages['careers'];

const schemas = [
  localBusiness(),
  breadcrumbList([
    { name: 'Home', url: site.url },
    { name: `${service.name} Renovation`, url: `${site.url}/${service.slug}` },
    { name: 'Careers', url: `${site.url}/${service.slug}/careers` },
  ]),
];
---

<BaseLayout title={seo.title} description={seo.description} ogImage={`https://${site.domain}/assets/img/og/${service.slug}.png`} schema={schemas}>
  <ServiceHero
    title={`Join the MTC ${service.name} Team`}
    subtitle="We're hiring skilled tradespeople in Hamilton and the GTA"
    backgroundImage={`/assets/img/${service.slug}/hero.jpg`}
    ctaText="Apply Now"
    ctaLink="#apply"
  />

  <section class="py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <h2 class="fw-bold mb-3">Why Work at MTC Renovations?</h2>
          <p class="text-secondary mb-4">
            MTC Renovations is growing and we need skilled, reliable people to join our team. We offer competitive pay, steady work, and a professional environment where quality matters.
          </p>

          <div class="row g-3 mb-5">
            <div class="col-md-6">
              <div class="d-flex align-items-start gap-2">
                <i class="fas fa-check text-danger mt-1"></i>
                <span>Competitive hourly rates</span>
              </div>
            </div>
            <div class="col-md-6">
              <div class="d-flex align-items-start gap-2">
                <i class="fas fa-check text-danger mt-1"></i>
                <span>Steady, year-round work</span>
              </div>
            </div>
            <div class="col-md-6">
              <div class="d-flex align-items-start gap-2">
                <i class="fas fa-check text-danger mt-1"></i>
                <span>Professional work environment</span>
              </div>
            </div>
            <div class="col-md-6">
              <div class="d-flex align-items-start gap-2">
                <i class="fas fa-check text-danger mt-1"></i>
                <span>Growth opportunities</span>
              </div>
            </div>
          </div>

          <h3 class="fw-bold mb-3" id="apply">Apply Now</h3>
          <p class="text-secondary mb-3">
            Send your resume and a brief introduction to <a href={`mailto:${site.email}`} class="text-danger">{site.email}</a> with the subject line "Career Application - {service.name}".
          </p>
          <p class="text-secondary">
            Or call us at <a href="tel:6475601095" class="text-danger fw-bold">(647) 560-1095</a> to speak with our team directly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Know Someone Who'd Be a Great Fit?"
    subtitle="Share this page with skilled tradespeople in Hamilton."
    ctaText="Call Us"
    ctaLink="tel:6475601095"
  />
</BaseLayout>
